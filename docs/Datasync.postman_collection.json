{
  "info": {
    "_postman_id": "74328622-0484-49ff-9381-f6520e2087be",
    "name": "Datasync",
    "description": "The **Datasync** collection provides a complete set of API endpoints for a role-based data synchronization platform. It covers Firebase-based authentication, user profile retrieval, and role-specific workflows for two user types **User A** and **User B**. User A can submit company details and view their own submissions and uploaded images, while User B can access User A's latest submission and upload images to User A's account. All protected endpoints require a Bearer token obtained from the Firebase login endpoint.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "24950715"
  },
